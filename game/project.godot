; Engine configuration file.
; Minimal Godot 4.6 vertical slice prototype.

config_version=5

[application]

config/name="Réseau Intime Prototype"
run/main_scene="res://scenes/portrait/PortraitMain.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/core/GameState.gd"
DataLoader="*res://scripts/core/DataLoader.gd"
TimelineState="*res://scripts/core/TimelineState.gd"
EffectApplier="*res://scripts/core/EffectApplier.gd"
DebugRouteProbe="*res://scripts/core/DebugRouteProbe.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
