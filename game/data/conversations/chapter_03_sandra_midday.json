          "sender": "sandra",
          "time_label": "12:20",
          "text": "Je crois que j’aime surtout les phrases qui ont l’air sûres d’elles."
        },
        {
          "id": "msg_c03_sandra_midday_008",
          "sender": "sandra",
          "time_label": "12:20",
          "text": "Puis elles me laissent réfléchir au lieu d’aller trop vite."
        },
        {
          "id": "msg_c03_sandra_midday_009",
          "sender": "sandra",
          "time_label": "12:20",
          "text": "Ne te moque pas trop, je fais ma snob très sérieuse."
