          "sender": "sandra",
          "time_label": "12:19",
          "text": "Le roman est idiot, mais la page du lac est jolie."
        },
        {
          "id": "msg_c03_sandra_midday_005",
          "sender": "sandra",
          "time_label": "12:19",
          "text": "Je lis plus lentement quand je sais que quelqu’un peut me demander ce que j’en pense."
        },
        {
          "id": "msg_c03_sandra_midday_006",
          "sender": "sandra",
          "time_label": "12:19",
          "text": "Ça me donne envie de lever les yeux et pas seulement de tourner la page."
        }
      ],
      "choices": [
        {
          "id": "choice_c03_sandra_midday_04",
          "text": "Je veux la page du lac.",
          "tone": "tendre"
        },
        {
          "id": "choice_c03_sandra_midday_05",
          "text": "Tu lis à ton rythme.",
          "tone": "prudent"
        },
        {
          "id": "choice_c03_sandra_midday_06",
          "text": "Tu peux garder le silence.",
          "tone": "calme"
