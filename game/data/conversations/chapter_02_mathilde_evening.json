          "sender": "mathilde",
          "time_label": "17:52",
          "text": "Peut-être un peu."
        }
      ],
      "choices": [
        {
          "id": "choice_c02_mathilde_evening_01_1",
          "text": "Tu veux que je prévienne l’entrée ?",
