            {
              "id": "msg_c02_raphaelle_midday_012",
              "sender": "raphaelle",
              "time_label": "12:27",
              "text": "Mais oui."
            },
            {
              "id": "msg_c02_raphaelle_midday_013",
              "sender": "raphaelle",
              "time_label": "12:27",
              "text": "J’aime bien trouver le truc qui tombe juste."
