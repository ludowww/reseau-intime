          "id": "msg_c02_raphaelle_midday_007",
          "sender": "raphaelle",
          "time_label": "12:27",
          "text": "Ce n’est pas exactement un outil pro."
        }
      ],
      "choices": [
        {
          "id": "choice_c02_raphaelle_midday_01_1",
          "text": "Merci, c’est utile. Je regarderai ça.",
          "tone": "pro",
          "next_messages": [
            {
              "id": "msg_c02_raphaelle_midday_008",
              "sender": "raphaelle",
              "time_label": "12:27",
              "text": "Parfait."
            },
            {
              "id": "msg_c02_raphaelle_midday_009",
              "sender": "raphaelle",
              "time_label": "12:27",
              "text": "Je me suis dit que ça pouvait te faire gagner du temps."
            },
            {
              "id": "msg_c02_raphaelle_midday_010",
              "sender": "raphaelle",
              "time_label": "12:27",
              "text": "Et j’aime bien quand les choses font gagner du temps aux gens."
            }
          ]
        },
        {
          "id": "choice_c02_raphaelle_midday_01_2",
          "text": "Donc tu fais plaisir aux gens avec des jeux vidéo ?",
