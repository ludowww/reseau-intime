          "sender": "sandra",
          "time_label": "18:38",
          "text": "Je n’ai pas racheté de tomates."
        },
        {
          "id": "msg_c02_sandra_evening_002",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "Je tenais à te rassurer."
        },
        {
          "id": "msg_c02_sandra_evening_003",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "À la place, je suis passée marcher près du lac."
        },
        {
          "id": "msg_c02_sandra_evening_004",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "Et j’ai lu trois pages de mon roman beaucoup trop sentimental."
        },
        {
          "id": "msg_c02_sandra_evening_005",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "Photo envoyée.",
          "content_id": "sandra_j2_lake_book_soft_placeholder"
        },
        {
          "id": "msg_c02_sandra_evening_006",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "Il y avait du vent."
        },
        {
          "id": "msg_c02_sandra_evening_007",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "Et une dame très investie dans la vie de son chien."
        },
        {
          "id": "msg_c02_sandra_evening_008",
          "sender": "sandra",
          "time_label": "18:38",
          "text": "Difficile de se concentrer sur une déclaration d’amour dans ces conditions."
        }
      ],
      "choices": [
        {
          "id": "choice_c02_sandra_evening_01_1",
          "text": "J’aime bien t’imaginer là-bas.",
          "tone": "doux",
          "next_messages": [
            {
              "id": "msg_c02_sandra_evening_009",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Ne rends pas ça trop joli."
            },
            {
              "id": "msg_c02_sandra_evening_010",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "J’avais froid aux mains."
            },
            {
              "id": "msg_c02_sandra_evening_011",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Et mon marque-page s’est envolé."
            },
            {
              "id": "msg_c02_sandra_evening_012",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Mais… oui."
            },
            {
              "id": "msg_c02_sandra_evening_013",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "C’était bien."
            }
          ]
        },
        {
          "id": "choice_c02_sandra_evening_01_2",
          "text": "Le chien a ruiné la romance ?",
          "tone": "taquin",
          "next_messages": [
            {
              "id": "msg_c02_sandra_evening_014",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Totalement."
            },
            {
              "id": "msg_c02_sandra_evening_015",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Il s’appelait Mozart."
            },
            {
              "id": "msg_c02_sandra_evening_016",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Impossible de rivaliser avec un chien qui s’appelle Mozart."
            }
          ]
        },
        {
          "id": "choice_c02_sandra_evening_01_3",
          "text": "Ça avait l’air calme.",
          "tone": "prudent",
          "next_messages": [
            {
              "id": "msg_c02_sandra_evening_017",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Oui."
            },
            {
              "id": "msg_c02_sandra_evening_018",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "C’est ce que je cherchais."
            },
            {
              "id": "msg_c02_sandra_evening_019",
              "sender": "sandra",
              "time_label": "18:38",
              "text": "Un endroit où il n’y avait rien à expliquer."
